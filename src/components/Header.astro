---
import type { Locale } from "../i18n/locales";
import { useTranslations, localizePath } from "../i18n/utils";
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const baseUrl = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
const logoSrc = `${baseUrl}ltxlogo-nobg3.png`;

const navLinks = [
	{ href: localizePath(lang, ""), label: t.nav.home },
	{ href: localizePath(lang, "about/"), label: t.nav.about },
	{ href: localizePath(lang, "products/"), label: t.nav.products },
	{ href: `${localizePath(lang, "products/")}#papp`, label: t.nav.applications },
	{ href: localizePath(lang, "reference/"), label: t.nav.reference },
	{ href: `${localizePath(lang, "")}#contact`, label: t.nav.contact },
];
---

<header class="sticky top-0 z-100 border-b border-white/10 bg-bg/95 py-3 backdrop-blur-md">
	<nav class="mx-auto flex max-w-[1100px] items-center justify-between px-4 sm:px-6">
		<a href={localizePath(lang, "")} class="flex items-center gap-2 text-text no-underline hover:opacity-90">
			<img src={logoSrc} alt={t.common.siteShortName} class="h-12 w-auto" width="160" height="55" />
		</a>
		<div class="flex flex-wrap items-center justify-end gap-4 sm:gap-6">
			{navLinks.map((link) => (
				<a href={link.href} class="text-[0.8125rem] font-medium uppercase tracking-wide text-muted hover:text-text sm:text-[0.9375rem]">
					{link.label}
				</a>
			))}
			<LanguageSwitcher lang={lang} />
		</div>
	</nav>
</header>

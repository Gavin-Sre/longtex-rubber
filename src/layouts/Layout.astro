---
import "../styles/global.css";
import { defaultLocale, hreflangMap, locales, ogLocaleMap, type Locale } from "../i18n/locales";
import { getLangFromUrl, getLocalizedPath } from "../i18n/utils";

interface Props {
	title: string;
	description?: string;
	keywords?: string;
	ogImage?: string;
	/** Active locale for this page. Defaults to URL-derived locale. */
	lang?: Locale;
}

const {
	title,
	description = "Longtex Rubber Industry is a leading rubber thread manufacturer in Thailand, supplying high-quality natural latex rubber thread for textile, food, and industrial applications. Trusted global supplier for OEM and export markets.",
	keywords,
	ogImage,
	lang = getLangFromUrl(Astro.url),
} = Astro.props;

const baseUrl = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
const siteOrigin = Astro.site?.href ?? "https://www.longtex.co.th";
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const ogImageUrl = new URL(ogImage ?? "rubber-tapping.jpg", siteOrigin).href;

const alternates = locales.map((loc) => ({
	hreflang: hreflangMap[loc],
	href: new URL(getLocalizedPath(loc, Astro.url), siteOrigin).href,
}));
const xDefaultHref = new URL(getLocalizedPath(defaultLocale, Astro.url), siteOrigin).href;

const organizationSchema = {
	"@context": "https://schema.org",
	"@type": "Organization",
	"@id": `${siteOrigin}#organization`,
	"name": "Longtex Rubber Industry Co., Ltd.",
	"alternateName": "Longtex",
	"url": siteOrigin,
	"logo": {
		"@type": "ImageObject",
		"url": new URL("ltxlogo-nobg3.png", siteOrigin).href,
	},
	"description": "Thailand-based manufacturer of extruded natural rubber threads. ISO certified. Products include silicone-coated, talcum-coated, and food-grade rubber threads for textile, medical, and industrial applications.",
	"address": {
		"@type": "PostalAddress",
		"streetAddress": "121/32 Moo 8 Soi Suksawad 74, Suksawad Rd., Bangkru",
		"addressLocality": "Prapradaeng",
		"addressRegion": "Samutprakarn",
		"postalCode": "10130",
		"addressCountry": "TH",
	},
	"areaServed": "Worldwide",
	"knowsAbout": [
		"Extruded rubber thread manufacturing",
		"Natural latex processing",
		"ISO 9001 certified rubber products",
		"Silicone-coated rubber threads",
		"Food-grade rubber threads",
		"Talcum-coated rubber threads",
	],
};
---

<!doctype html>
<html lang={hreflangMap[lang]}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta http-equiv="X-UA-Compatible" content="ie=edge" />

		<link rel="icon" href={`${baseUrl}ltxlogo-nobg3.png`} type="image/png" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<link rel="shortcut icon" href={`${baseUrl}favicon.ico`} type="image/x-icon" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		{keywords && <meta name="keywords" content={keywords} />}
		<link rel="canonical" href={canonicalURL} />

		<!-- hreflang alternates for international SEO -->
		{alternates.map((alt) => (
			<link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
		))}
		<link rel="alternate" hreflang="x-default" href={xDefaultHref} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Longtex Rubber Industry Co., Ltd." />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:locale" content={ogLocaleMap[lang]} />
		{locales.filter((l) => l !== lang).map((l) => (
			<meta property="og:locale:alternate" content={ogLocaleMap[l]} />
		))}
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={title} />

		<!-- Twitter / X card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<!-- Crawl directives -->
		<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
		<link rel="sitemap" href={`${baseUrl}sitemap-index.xml`} />

		<!-- Organization structured data (site-wide) -->
		<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

		<!-- Per-page head content (e.g. additional JSON-LD) -->
		<slot name="head" />

		<!-- Google Fonts: preconnect + preload primary weight for LCP performance -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preload" as="font" type="font/woff2" href="https://fonts.gstatic.com/s/plusjakartasans/v8/LDIoaomQNQcsA88c7O9yZ4KMCoOg4IA6-91aHEjcWuA_KU7NSg.woff2" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

		<!-- Google Analytics -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-G5X1E0EXYF"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-G5X1E0EXYF');
		</script>
	</head>
	<body class="min-h-screen bg-bg font-sans text-text antialiased">
		<slot />
	</body>
</html>

---
import type { Locale } from "../i18n/locales";
import { defaultLocale } from "../i18n/locales";
import { useTranslations } from "../i18n/utils";

interface Props {
	lang?: Locale;
}

const { lang = defaultLocale } = Astro.props;
const t = useTranslations(lang);

interface ApplicationItem {
	title: string;
	description: string;
	icon: "sports" | "packaging" | "socks" | "food" | "medical";
	span?: "wide" | "normal";
}

const applications: ApplicationItem[] = [
	{ title: t.applications.sports.title, description: t.applications.sports.description, icon: "sports", span: "wide" },
	{ title: t.applications.food.title, description: t.applications.food.description, icon: "food", span: "wide" },
	{ title: t.applications.socks.title, description: t.applications.socks.description, icon: "socks" },
	{ title: t.applications.packaging.title, description: t.applications.packaging.description, icon: "packaging" },
	{ title: t.applications.medical.title, description: t.applications.medical.description, icon: "medical" },
];
---

<div class="grid grid-cols-1 gap-4 sm:grid-cols-3" data-product-apps>
	{applications.map((item, i) => (
		<a
			class={`bento-card relative flex flex-col gap-4 overflow-hidden rounded-2xl border border-white/[0.06] bg-surface p-7 no-underline cursor-pointer transition-[border-color,transform] duration-200 ease-out hover:border-accent/30 hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 before:absolute before:inset-y-0 before:left-0 before:w-[3px] before:rounded-l-2xl before:bg-accent before:opacity-70 before:content-[''] after:absolute after:-bottom-4 after:-right-4 after:size-28 after:rounded-full after:bg-accent after:opacity-[0.03] after:pointer-events-none after:content-[''] ${i === 0 ? "sm:col-span-2" : ""}`}
			style={`--i: ${i}`}
		>
			<div class="size-10 shrink-0 text-accent" aria-hidden="true">
				{item.icon === "sports" && (
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="10" />
						<path d="M4.93 4.93C6.58 7.6 7 9.8 7 12s-.42 4.4-2.07 7.07M19.07 4.93C17.42 7.6 17 9.8 17 12s.42 4.4 2.07 7.07M2 12h20" />
					</svg>
				)}
				{item.icon === "food" && (
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z" />
						<path d="M8 9h.01M16 9h.01M8 14s1.5 2 4 2 4-2 4-2" />
					</svg>
				)}
				{item.icon === "socks" && (
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M6 3h12v11l-4 4H6V3z" />
						<path d="M14 14l4 4a2 2 0 0 1-2.83 2.83L10 15.66" />
						<path d="M6 8h12" />
					</svg>
				)}
				{item.icon === "packaging" && (
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
					</svg>
				)}
				{item.icon === "medical" && (
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="3" y="3" width="18" height="18" rx="3" />
						<path d="M12 8v8M8 12h8" />
					</svg>
				)}
			</div>
			<div class="flex flex-col gap-1.5">
				<h3 class="m-0 text-base font-bold leading-tight text-text">{item.title}</h3>
				<p class="m-0 text-[0.8125rem] leading-relaxed text-text-muted">{item.description}</p>
			</div>
		</a>
	))}
</div>

<style>
	.bento-card {
		opacity: 0;
		transform: translateY(1rem);
	}
	@media (prefers-reduced-motion: no-preference) {
		[data-product-apps].is-in-view .bento-card {
			animation: bento-rise 0.5s ease-out forwards;
			animation-delay: calc(var(--i) * 0.08s);
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.bento-card { opacity: 1; transform: none; }
	}
	@keyframes bento-rise {
		from { opacity: 0; transform: translateY(1rem); }
		to   { opacity: 1; transform: translateY(0); }
	}
</style>

<script>
	(function () {
		const el = document.querySelector("[data-product-apps]");
		if (!el) return;
		if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
			el.classList.add("is-in-view");
			return;
		}
		const observer = new IntersectionObserver(
			(entries) => entries.forEach((e) => { if (e.isIntersecting) el.classList.add("is-in-view"); }),
			{ rootMargin: "0px 0px -8% 0px", threshold: 0 }
		);
		observer.observe(el);
	})();
</script>

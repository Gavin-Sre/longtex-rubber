---
/** One product block: spec table on top, Embla carousel below. */
interface TableRow {
	count: string;
	cells: (boolean | string)[];
}

interface HeaderCell {
	text: string;
	rowspan?: number;
	colspan?: number;
}

interface Props {
	id: string;
	title: string;
	/** Omit when placeholder is true */
	images?: string[];
	/** First header row: Count, Packaging (kg./box), Color, Elongation At Break (with rowspan/colspan) */
	tableHeaderRow1?: HeaderCell[];
	/** Second header row: 20, 23, 25, 32, 34, Black, White (sub-labels under Packaging and Color) */
	tableHeaderRow2?: string[];
	tableRows?: TableRow[];
	/** Title + optional slot only; no spec table or carousel */
	placeholder?: boolean;
	/** Optional override for the placeholder body copy (defaults to English fallback). */
	placeholderText?: string;
}

const {
	id,
	title,
	images = [],
	tableHeaderRow1 = [],
	tableHeaderRow2,
	tableRows = [],
	placeholder = false,
	placeholderText = "Specifications and imagery for specialized threads (UV resistance, fire retardancy, custom colors, and more) will be published here soon.",
} = Astro.props;
const thClass = "border border-white/[0.06] bg-white/[0.03] px-4 py-3 text-center text-[0.7rem] font-semibold uppercase tracking-[0.14em] text-text";
const tdBaseClass = "border border-white/[0.06] px-4 py-3 text-sm";
---

<section id={id} class="product-section scroll-mt-24 border-b border-white/10 py-12 first:pt-4" data-product-section>
	<h2 class="mb-6 text-center text-2xl font-bold tracking-tight md:text-3xl">{title}</h2>

	{placeholder ? (
		<div class="mx-auto max-w-2xl text-center">
			<p class="m-0 text-[1.0625rem] leading-[1.7] text-text-muted">
				{placeholderText}
			</p>
		</div>
	) : (
		<>
	<!-- Spec table card -->
	<div class="overflow-hidden rounded-2xl bg-surface shadow-xl shadow-black/30 ring-1 ring-white/[0.06]">
		<div class="relative">
			<div
				aria-hidden="true"
				class="pointer-events-none absolute inset-x-0 top-0 z-10 h-px bg-gradient-to-r from-transparent via-accent/60 to-transparent"
			/>
			<div class="overflow-x-auto">
				<table class="spec-table w-full min-w-[520px] border-collapse text-sm" role="grid">
					<thead>
						<tr>
							{tableHeaderRow1.map((cell) => (
								<th
									class={thClass}
									scope="col"
									rowspan={cell.rowspan ?? 1}
									colspan={cell.colspan ?? 1}
								>
									{cell.text}
								</th>
							))}
						</tr>
						{tableHeaderRow2 && tableHeaderRow2.length > 0 && (
							<tr>
								{tableHeaderRow2.map((label) => (
									<th class={thClass} scope="col">
										{label}
									</th>
								))}
							</tr>
						)}
					</thead>
					<tbody>
						{tableRows.map((row) => (
							<tr class="transition-colors duration-150 hover:bg-white/[0.025]">
								<td class={`${tdBaseClass} font-semibold text-text`}>{row.count}</td>
								{row.cells.map((cell) => (
									<td class={`${tdBaseClass} text-center`}>
										{typeof cell === "boolean" ? (
											cell ? (
												<svg
													xmlns="http://www.w3.org/2000/svg"
													class="mx-auto h-4 w-4 text-accent"
													viewBox="0 0 20 20"
													fill="currentColor"
													aria-label="Available"
													role="img"
												>
													<path fill-rule="evenodd" d="M16.704 5.29a1 1 0 010 1.42l-7.5 7.5a1 1 0 01-1.42 0l-3.5-3.5a1 1 0 011.42-1.42L8.5 12.08l6.79-6.79a1 1 0 011.414 0z" clip-rule="evenodd" />
												</svg>
											) : (
												<span class="text-text-muted/40" aria-label="Not available">—</span>
											)
										) : (
											<span class="text-text-muted">{cell}</span>
										)}
									</td>
								))}
							</tr>
						))}
					</tbody>
				</table>
			</div>
		</div>
	</div>

	<!-- Carousel below -->
	<div class="embla mt-8" id={`embla-${id}`} data-embla>
		<div class="embla__viewport overflow-hidden rounded-lg" data-embla-viewport>
			<div class="embla__container flex touch-pan-y gap-4" data-embla-container>
				{images.map((src) => (
					<div class="embla__slide min-w-0 flex-[0_0_100%]" data-embla-slide>
						<img
							src={src}
							alt=""
							class="h-auto w-full rounded-lg object-cover"
							width="800"
							height="500"
							loading="lazy"
						/>
					</div>
				))}
			</div>
		</div>
		<div class="embla__controls mt-4 flex items-center justify-center gap-4" data-embla-controls>
			<button
				type="button"
				class="embla__prev flex h-10 w-10 items-center justify-center rounded-full border border-white/30 bg-white/10 text-white transition hover:bg-white/20 disabled:opacity-40"
				aria-label="Previous slide"
				data-embla-prev
			>
				<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
				</svg>
			</button>
			<div class="embla__dots flex gap-2" data-embla-dots></div>
			<button
				type="button"
				class="embla__next flex h-10 w-10 items-center justify-center rounded-full border border-white/30 bg-white/10 text-white transition hover:bg-white/20 disabled:opacity-40"
				aria-label="Next slide"
				data-embla-next
			>
				<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
				</svg>
			</button>
		</div>
	</div>
		</>
	)}
</section>

---
import { locales, localeNames, localeShortNames, type Locale } from "../i18n/locales";
import { getLocalizedPath } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const items = locales.map((loc) => ({
	loc,
	name: localeNames[loc],
	short: localeShortNames[loc],
	href: getLocalizedPath(loc, Astro.url),
	active: loc === lang,
}));
const current = items.find((i) => i.active)!;
---

<details class="group relative" data-lang-switcher>
	<summary
		class="flex cursor-pointer items-center gap-1.5 rounded-full border border-white/[0.08] bg-white/[0.03] px-3 py-1.5 text-[0.8125rem] font-semibold tracking-wide text-text transition-colors hover:border-accent/40 hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/60"
		aria-label={t.langSwitcher.label}
	>
		<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<circle cx="12" cy="12" r="10" />
			<path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
		</svg>
		<span>{current.short}</span>
		<svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<path d="M6 9l6 6 6-6" />
		</svg>
	</summary>
	<div class="absolute right-0 top-[calc(100%+0.5rem)] z-50 w-44 overflow-hidden rounded-xl border border-white/[0.08] bg-surface shadow-xl shadow-black/40 ring-1 ring-white/[0.04]">
		<ul class="m-0 list-none p-1.5">
			{items.map((item) => (
				<li>
					<a
						href={item.href}
						hreflang={item.loc}
						aria-current={item.active ? "true" : undefined}
						class:list={[
							"flex items-center justify-between gap-3 rounded-lg px-3 py-2 text-[0.8125rem] no-underline transition-colors",
							item.active
								? "bg-accent/10 text-accent"
								: "text-text-muted hover:bg-white/[0.04] hover:text-text",
						]}
					>
						<span class="font-medium">{item.name}</span>
						<span class="text-[0.6875rem] font-semibold uppercase tracking-wider opacity-70">{item.short}</span>
					</a>
				</li>
			))}
		</ul>
	</div>
</details>

<script>
	(function () {
		document.addEventListener("click", (event) => {
			const target = event.target as HTMLElement;
			document.querySelectorAll<HTMLDetailsElement>("[data-lang-switcher]").forEach((el) => {
				if (el.open && !el.contains(target)) el.open = false;
			});
		});
		document.addEventListener("keydown", (event) => {
			if (event.key !== "Escape") return;
			document.querySelectorAll<HTMLDetailsElement>("[data-lang-switcher]").forEach((el) => {
				if (el.open) el.open = false;
			});
		});
	})();
</script>
